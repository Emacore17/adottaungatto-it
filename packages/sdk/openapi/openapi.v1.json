{
  "openapi": "3.0.3",
  "info": {
    "title": "AdottaUnGatto API",
    "version": "1.0.0",
    "description": "OpenAPI source for the v1 HTTP contract used by generated SDK types."
  },
  "servers": [
    {
      "url": "http://localhost:3002"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "security": [],
        "responses": {
          "200": {
            "description": "API health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health/search": {
      "get": {
        "operationId": "getSearchHealth",
        "security": [],
        "responses": {
          "200": {
            "description": "Search health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchHealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "responses": {
          "200": {
            "description": "Current authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateCurrentUserPreferences",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePreferencesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/profile": {
      "get": {
        "operationId": "getCurrentUserProfile",
        "responses": {
          "200": {
            "description": "Current user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateCurrentUserProfile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/avatar": {
      "post": {
        "operationId": "upsertCurrentUserAvatar",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertAvatarRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteCurrentUserAvatar",
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/consents": {
      "get": {
        "operationId": "getCurrentUserConsents",
        "responses": {
          "200": {
            "description": "Current consent states",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsentsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateCurrentUserConsents",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateConsentsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated consent states",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsentsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/favorites": {
      "get": {
        "operationId": "getCurrentUserFavorites",
        "responses": {
          "200": {
            "description": "Current user favorites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FavoritesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/favorites/{listingId}": {
      "put": {
        "operationId": "addCurrentUserFavorite",
        "parameters": [
          {
            "$ref": "#/components/parameters/ListingId"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated favorites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FavoritesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "operationId": "deleteCurrentUserFavorite",
        "parameters": [
          {
            "$ref": "#/components/parameters/ListingId"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated favorites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FavoritesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/linked-identities": {
      "get": {
        "operationId": "getCurrentUserLinkedIdentities",
        "responses": {
          "200": {
            "description": "Linked external identities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkedIdentitiesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/linked-identities/{provider}/start": {
      "post": {
        "operationId": "startCurrentUserLinkedIdentity",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProviderAlias"
          }
        ],
        "responses": {
          "200": {
            "description": "Identity linking start information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartLinkedIdentityResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/linked-identities/{provider}": {
      "delete": {
        "operationId": "deleteCurrentUserLinkedIdentity",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProviderAlias"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated linked identities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkedIdentitiesResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/v1/users/me/sessions": {
      "get": {
        "operationId": "getCurrentUserSessions",
        "responses": {
          "200": {
            "description": "Active sessions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/users/me/sessions/{sessionId}": {
      "delete": {
        "operationId": "deleteCurrentUserSession",
        "parameters": [
          {
            "$ref": "#/components/parameters/SessionId"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated sessions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "ListingId": {
        "name": "listingId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[1-9]\\\\d*$"
        }
      },
      "ProviderAlias": {
        "name": "provider",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]{0,62}$"
        }
      },
      "SessionId": {
        "name": "sessionId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Request validation failed",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "statusCode": {
            "type": "number"
          },
          "message": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "error": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": ["status", "service", "timestamp"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok"]
          },
          "service": {
            "type": "string",
            "enum": ["api"]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SearchHealthResponse": {
        "type": "object",
        "required": ["status", "service", "index", "timestamp"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "degraded"]
          },
          "service": {
            "type": "string",
            "enum": ["search"]
          },
          "index": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserRole": {
        "type": "string",
        "enum": ["user", "moderator", "admin"]
      },
      "IdentityProvider": {
        "type": "string",
        "enum": ["dev-header", "keycloak"]
      },
      "UserPreferences": {
        "type": "object",
        "required": ["messageEmailNotificationsEnabled"],
        "properties": {
          "messageEmailNotificationsEnabled": {
            "type": "boolean"
          }
        }
      },
      "UpdatePreferencesRequest": {
        "type": "object",
        "required": ["messageEmailNotificationsEnabled"],
        "additionalProperties": false,
        "properties": {
          "messageEmailNotificationsEnabled": {
            "type": "boolean"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "provider",
          "providerSubject",
          "email",
          "emailVerified",
          "roles",
          "preferences",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/IdentityProvider"
          },
          "providerSubject": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserRole"
            }
          },
          "preferences": {
            "$ref": "#/components/schemas/UserPreferences"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MeResponse": {
        "type": "object",
        "required": ["user"],
        "properties": {
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "displayName",
          "phoneE164",
          "phoneVerifiedAt",
          "city",
          "province",
          "bio",
          "avatarStorageKey",
          "avatarObjectUrl",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "phoneE164": {
            "type": "string",
            "nullable": true
          },
          "phoneVerifiedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "province": {
            "type": "string",
            "nullable": true
          },
          "bio": {
            "type": "string",
            "nullable": true
          },
          "avatarStorageKey": {
            "type": "string",
            "nullable": true
          },
          "avatarObjectUrl": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "ProfileResponse": {
        "type": "object",
        "required": ["profile"],
        "properties": {
          "profile": {
            "$ref": "#/components/schemas/UserProfile"
          }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": false,
        "properties": {
          "firstName": {
            "type": "string",
            "nullable": true,
            "maxLength": 80
          },
          "lastName": {
            "type": "string",
            "nullable": true,
            "maxLength": 80
          },
          "displayName": {
            "type": "string",
            "nullable": true,
            "maxLength": 120
          },
          "phoneE164": {
            "type": "string",
            "nullable": true,
            "maxLength": 20
          },
          "city": {
            "type": "string",
            "nullable": true,
            "maxLength": 120
          },
          "province": {
            "type": "string",
            "nullable": true,
            "maxLength": 120
          },
          "bio": {
            "type": "string",
            "nullable": true,
            "maxLength": 800
          }
        }
      },
      "UpsertAvatarRequest": {
        "type": "object",
        "required": ["mimeType", "contentBase64"],
        "additionalProperties": false,
        "properties": {
          "mimeType": {
            "type": "string",
            "maxLength": 120
          },
          "contentBase64": {
            "type": "string"
          },
          "fileName": {
            "type": "string",
            "nullable": true,
            "maxLength": 180
          }
        }
      },
      "ConsentType": {
        "type": "string",
        "enum": ["privacy", "terms", "marketing"]
      },
      "UserConsent": {
        "type": "object",
        "required": ["type", "granted", "version", "grantedAt", "source"],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ConsentType"
          },
          "granted": {
            "type": "boolean"
          },
          "version": {
            "type": "string",
            "nullable": true
          },
          "grantedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "source": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ConsentsResponse": {
        "type": "object",
        "required": ["consents"],
        "properties": {
          "consents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserConsent"
            }
          }
        }
      },
      "ConsentUpdate": {
        "type": "object",
        "required": ["type", "granted", "version"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ConsentType"
          },
          "granted": {
            "type": "boolean"
          },
          "version": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "source": {
            "type": "string",
            "minLength": 2,
            "maxLength": 64
          }
        }
      },
      "UpdateConsentsRequest": {
        "type": "object",
        "required": ["consents"],
        "additionalProperties": false,
        "properties": {
          "consents": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "$ref": "#/components/schemas/ConsentUpdate"
            }
          }
        }
      },
      "UserFavorite": {
        "type": "object",
        "required": ["listingId", "addedAt"],
        "properties": {
          "listingId": {
            "type": "string"
          },
          "addedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FavoritesResponse": {
        "type": "object",
        "required": ["favorites"],
        "properties": {
          "favorites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserFavorite"
            }
          }
        }
      },
      "LinkedIdentity": {
        "type": "object",
        "required": [
          "provider",
          "providerSubject",
          "emailAtLink",
          "linkedAt",
          "lastSeenAt",
          "isPrimary"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "providerSubject": {
            "type": "string"
          },
          "emailAtLink": {
            "type": "string",
            "nullable": true
          },
          "linkedAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastSeenAt": {
            "type": "string",
            "format": "date-time"
          },
          "isPrimary": {
            "type": "boolean"
          }
        }
      },
      "LinkedIdentitiesResponse": {
        "type": "object",
        "required": ["linkedIdentities"],
        "properties": {
          "linkedIdentities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LinkedIdentity"
            }
          }
        }
      },
      "StartLinkedIdentityResponse": {
        "type": "object",
        "required": ["provider", "redirectUrl"],
        "properties": {
          "provider": {
            "type": "string"
          },
          "redirectUrl": {
            "type": "string"
          }
        }
      },
      "UserSession": {
        "type": "object",
        "required": ["sessionId", "clientId", "ipAddress", "startedAt", "lastSeenAt", "isCurrent"],
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "clientId": {
            "type": "string",
            "nullable": true
          },
          "ipAddress": {
            "type": "string",
            "nullable": true
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastSeenAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isCurrent": {
            "type": "boolean"
          }
        }
      },
      "SessionsResponse": {
        "type": "object",
        "required": ["sessions"],
        "properties": {
          "sessions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserSession"
            }
          }
        }
      }
    }
  }
}
