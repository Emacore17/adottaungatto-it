MESSAGE_MESSAGE_MAX_URLS=4
MESSAGE_DUPLICATE_WINDOW_SECONDS=120
MESSAGE_TYPING_EVENT_WINDOW_SECONDS=15
MESSAGE_TYPING_EVENT_MAX_REQUESTS=20
MESSAGE_TYPING_EVENT_TTL_SECONDS=6
