{
  "realm": "adottaungatto",
  "enabled": true,
  "displayName": "adottaungatto-it",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 604800,
  "internationalizationEnabled": true,
  "supportedLocales": ["it", "en"],
  "defaultLocale": "it",
  "roles": {
    "realm": [
      {
        "name": "user"
      },
      {
        "name": "moderator"
      },
      {
        "name": "admin"
      }
    ]
  },
  "clients": [
    {
      "clientId": "adottaungatto-web",
      "name": "adottaungatto web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"]
    },
    {
      "clientId": "adottaungatto-admin",
      "name": "adottaungatto admin",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001"]
    },
    {
      "clientId": "adottaungatto-mobile",
      "name": "adottaungatto mobile",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "trustEmail": true,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "syncMode": "FORCE",
        "useJwksUrl": "true",
        "defaultScope": "openid profile email",
        "clientId": "__SET_KEYCLOAK_GOOGLE_CLIENT_ID__",
        "clientSecret": "__SET_KEYCLOAK_GOOGLE_CLIENT_SECRET__"
      }
    }
  ],
  "users": [
    {
      "username": "utente.demo",
      "firstName": "Utente",
      "lastName": "Demo",
      "email": "utente.demo@adottaungatto.local",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "demo1234",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "moderatore.demo",
      "firstName": "Moderatore",
      "lastName": "Demo",
      "email": "moderatore.demo@adottaungatto.local",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "demo1234",
          "temporary": false
        }
      ],
      "realmRoles": ["moderator"]
    },
    {
      "username": "admin.demo",
      "firstName": "Admin",
      "lastName": "Demo",
      "email": "admin.demo@adottaungatto.local",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "demo1234",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ]
}
